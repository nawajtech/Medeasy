# Copy to .env.production before building for live server:
#   cp .env.production.example .env.production
#
# Then edit VITE_API_BASE_URL to your live backend URL and run:
#   npm run build
#
# Examples:
#   Same server (frontend + API on one domain):  https://yourdomain.com/api
#   Separate API subdomain:                    https://api.yourdomain.com/api

VITE_API_BASE_URL=https://yourdomain.com/api
